{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node",
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "lib": ["ES2020", "DOM"]
    },
    "include": ["controller-client/**/*.ts"],
    "exclude": ["controller-client/ControllerBridge.ts", "controller-client/index.ts"]
}
